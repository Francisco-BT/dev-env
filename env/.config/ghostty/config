# =============================================================================
# Ghostty — tmux + Neovim
# =============================================================================

# -----------------------------------------------------------------------------
# Theme
# -----------------------------------------------------------------------------
# Ghostty + macOS appearance are the source of truth. Edit light:/dark: themes here.
# Neovim does not override terminal colors.
theme = light:DraculaAlucard,dark:DraculaPro
window-theme                 = system

# -----------------------------------------------------------------------------
# Window
# -----------------------------------------------------------------------------
fullscreen                   = true
confirm-close-surface        = false
window-padding-balance       = true
window-padding-color         = background
window-padding-x             = 0
window-padding-y             = 0
macos-titlebar-style         = transparent
macos-non-native-fullscreen  = true

# -----------------------------------------------------------------------------
# Background
# -----------------------------------------------------------------------------
background-opacity           = 0.85
background-blur              = false
alpha-blending               = linear-corrected
# background                 = 000000

# -----------------------------------------------------------------------------
# Font
# -----------------------------------------------------------------------------
font-family                  = "Berkeley Mono"
font-size                    = 15
font-synthetic-style         = false
font-thicken                 = true
font-thicken-strength        = 80
font-shaping-break           = cursor
font-feature                 = ss03
font-feature                 = ss06
font-feature                 = calt

# -----------------------------------------------------------------------------
# Cursor
# -----------------------------------------------------------------------------
# Neovim controls shape via escape sequences; blink via DEC mode 12.
shell-integration-features   = no-cursor,no-sudo,no-title
cursor-color                 = cell-foreground
cursor-text                  = cell-background
cursor-style                 = block
cursor-style-blink           =
cursor-invert-fg-bg          = true

# -----------------------------------------------------------------------------
# Terminal
# -----------------------------------------------------------------------------
scrollback-limit             = 10000000
resize-overlay               = never
focus-follows-mouse          = false

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
macos-option-as-alt          = left

# -----------------------------------------------------------------------------
# Keybinds
# -----------------------------------------------------------------------------
keybind = ctrl+enter=unbind
